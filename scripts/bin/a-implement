#!/bin/sh
# AGENTS framework -- launch Claude Code Implement agent
# https://github.com/user/agents
#
# Usage:
#   a-implement                          # fresh interactive session
#   a-implement continue                 # auto-detect task, pre-fill prompt
#   a-implement "Build the login page"   # custom initial prompt
set -e

AGENT="Implement"

# Find the most recently modified NNN-* task directory
current_task() {
  tasks_dir="${PWD}/.tasks"
  [ -d "$tasks_dir" ] || return 0
  ls -t "$tasks_dir" 2>/dev/null | grep -E '^[0-9]{3}-' | head -1
}

case "${1:-}" in
  continue)
    task=$(current_task)
    if [ -z "$task" ]; then
      echo "No task found in .tasks/" >&2
      exit 1
    fi
    echo "-> Continuing task: $task"
    exec claude --agent "$AGENT" "Continue task $task"
    ;;
  "")
    exec claude --agent "$AGENT"
    ;;
  *)
    exec claude --agent "$AGENT" "$1"
    ;;
esac
